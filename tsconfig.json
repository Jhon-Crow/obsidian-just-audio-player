{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2022",
		"moduleResolution": "bundler",
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"lib": [
			"DOM",
			"ES2022"
		],
		"types": [
			"node"
		],
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	]
}
